# URL of the deployed Cloudflare Worker that powers the "Ask Anything" chat.
# Copy this file to `.env` (committed, public URL is fine) or `.env.local`
# (gitignored) and fill in your Worker URL.
#
# Local dev:   VITE_CHAT_API_URL=http://localhost:8787
# Production:  VITE_CHAT_API_URL=https://portfolio-chat.<your-subdomain>.workers.dev
VITE_CHAT_API_URL=
